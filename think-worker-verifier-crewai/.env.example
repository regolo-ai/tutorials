# Credenziali del Provider (es. OpenAI, OpenRouter, LM Studio, Ollama, Groq, ecc.)
OPENAI_API_KEY=sk-...
# Se usi un provider OpenAI-compatible diverso da OpenAI, imposta il suo Base URL (es. http://localhost:1234/v1, https://api.groq.com/openai/v1)
# OPENAI_API_BASE=
# OPENAI_BASE_URL=

# Modelli differenziati per ruolo
THINKER_MODEL=gpt-4o
WORKER_MODEL=gpt-4o
VERIFIER_MODEL=gpt-4o

# Fallback se non definiti i modelli sopra
OPENAI_MODEL_NAME=gpt-4o

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TWV_MAX_RETRIES=2
TWV_MAX_REASSIGNS=2
TWV_MAX_REPLANS=2
TWV_VERBOSE=true
