# This is an example .env file for the PR Review Assistant project.
# Copy this file to .env and replace the placeholder values with your actual configuration.

# Sign Up for an API key at https://regolo.ai and replace the value below with your API key.
REGOLO_API_KEY=your-api-key-here
# Choose the model you want to use. You can find available models at https://regolo.ai/models.
REGOLO_CORE_MODEL=qwen3.5-122b