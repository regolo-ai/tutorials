# CrewAI RAG Binary Quantization Pipeline
# =========================================
# Copy this file to .env and fill in your configuration
#
# All configuration is loaded from environment variables at startup.

# ==========================
# OPENAI API CONFIGURATION
# ==========================

# Provider for embeddings: transformers, openai, groq, ollama
# - transformers: Local (sentence-transformers), no API key needed
# - openai: Uses OpenAI API or any openai-compatible endpoint
# - groq: Uses Groq API
# - ollama: Local inference via Ollama server
OPENAI_PROVIDER=openai

# Model name or path for embeddings
# - For transformers: "BAAI/bge-small-en-v1.5" (or local path)
# - For OpenAI: "text-embedding-3-small" or "text-embedding-3-large"
# - For Groq: "llama3.1:8b-instruct-fresh"
# - For Ollama: "nomic-embed-text" or similar
OPENAI_MODEL=Qwen3-Embedding-8B

# API base URL for openai-compatible providers
# - For OpenAI.com: leave as default "https://api.openai.com/v1"
# - For Ollama: leave default or use "http://localhost:11434"
# - For Regolo.ai: "https://api.regolo.ai/v1"
# - For custom endpoints: "https://your-api.com/embed"
OPENAI_API_BASE=https://api.regolo.ai/v1

# API key for the embedding provider
# Leave empty for transformers/local inference
# For other providers, use one of these standard variables:
# OPENAI_API_KEY=value
# Go to https://regolo.ai and get 30 days for free
OPENAI_API_KEY=

# ==========================
# OPENAI LLM CONFIGURATION 
# ==========================

# LLM Provider: openai, groq, regolo, ollama, or empty (uses fallback)
OPENAI_LLM_PROVIDER=

# LLM Model name
OPENAI_LLM_MODEL=qwen3:4b-thinking

# LLM API base (for openai-compatible providers)
OPENAI_LLM_API_BASE=https://api.openai.com/v1

# LLM API key (or use standard env vars: OPENAI_API_KEY)
OPENAI_LLM_API_KEY=

# ==============
# LEGACY SUPPORT
# ==============
# The following standards-compliant variables are also supported:
# OPENAI_API_KEY=sk-...  (set this if you use OPENAI_API_KEY)
# GROQ_API_KEY=gsk-...   (set this if using Groq)
# OLLAMA_API_KEY=        (unused, for compatibility)
