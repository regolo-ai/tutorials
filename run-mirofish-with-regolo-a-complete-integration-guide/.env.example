# Regolo API — copy this to .env and fill in your key
REGOLO_API_KEY=your_regolo_api_key_here
REGOLO_BASE_URL=https://api.regolo.ai/v1

# Model to use for MiroFish simulations
# Good starting point: Llama-3.1-8B-Instruct (fast, cheap, great for dev)
# Production runs:     Llama-3.3-70B-Instruct  or  qwen3.5-122b
LLM_MODEL_NAME=Llama-3.3-70B-Instruct

# Mem0 — open-source agent memory layer (https://github.com/mem0ai/mem0)
# No external account needed. Runs locally; uses regolo.ai for both LLM + embeddings.
MEM0_LLM_MODEL=Llama-3.3-70B-Instruct
MEM0_EMBEDDER_MODEL=Qwen3-Embedding-8B
