# Regolo.ai API Key - Get 30 days free https://regolo.ai/signup
REGOLO_API_KEY=your_api_key_here 
BASE_URL="https://api.regolo.ai/v1"

# Models
REGOLO_MAKER_MODEL="gpt-oss-120b"
REGOLO_CHECKER_MODEL="gemma4-31b"

# Code reviewer settings
MAX_ITERATIONS=3
DEFAULT_INPUT_COST_PER_1K=0.0020
DEFAULT_OUTPUT_COST_PER_1K=0.0060

# Qdrant retrieval layer
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
USE_QDRANT=true

# Reranker (Qwen3-Reranker-4B via Regolo)
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
RERANKER_ENDPOINT=
USE_RERANKER=true
