# Official OpenAI
OPENAI_MODEL=qwen3.5-9b
OPENAI_BASE_URL=https://api.regolo.ai/v1
OPENAI_API_KEY="REGOLO_API_KEY"

# Local OpenAI-compatible server example (vLLM / LM Studio / Ollama proxy)
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=not-needed-but-required-by-client
# OPENAI_MODEL=your-local-model-name

TARGET_REPO_PATH=./target-repo
AGENT_MAX_ATTEMPTS=3
AGENT_MODEL_CALL_LIMIT=12
AGENT_TOOL_CALL_LIMIT=30
# Default costs of model
INPUT_COST=0.07
OUTPUT_COST=0.35
# Default: 1€ euro 
MAX_COST=1.00